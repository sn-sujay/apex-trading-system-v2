# ================================================
# APEX TRADING SYSTEM - Environment Configuration
# ================================================
# Copy this file to .env and fill in your credentials
# cp .env.example .env

# =================
# TRADING MODE
# =================
PAPER_MODE=true
# Set to false ONLY when you have tested thoroughly in paper mode

# =================
# DHAN (Indian Stock Options) - Optional
# =================
DHAN_CLIENT_ID=
DHAN_CLIENT_SECRET=
DHAN_ACCESS_TOKEN=
# Get credentials from: https://dhan.co/

# =================
# BINANCE (Crypto) - Optional
# =================
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Get from: https://www.binance.com/en/api

# =================
# ALPHA VANTAGE (Market Data) - Optional
# =================
ALPHA_VANTAGE_API_KEY=
# Free key: https://www.alphavantage.co/support/#api-key

# =================
# TRADING ACCOUNTS
# =================
# Initial capital per exchange (in base currency)
INITIAL_CAPITAL_DHAN=1000000   # ₹10 lakhs for Indian options
INITIAL_CAPITAL_BINANCE=10000  # USDT for crypto
INITIAL_CAPITAL_FOREX=10000     # USD for forex

# =================
# RISK MANAGEMENT
# =================
MAX_DAILY_LOSS_PERCENT=5       # Max 5% daily loss
MAX_PER_TRADE_RISK_PERCENT=2   # Max 2% risk per trade
MAX_POSITIONS=5               # Max concurrent positions

# =================
# SERVER CONFIG
# =================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO